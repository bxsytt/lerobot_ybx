{
    "dataset": {
        "repo_id": null,
        "root": "/data/SJJ/UBT/x-humanoid/datasets/lerobot_v2/packing_box_episode_50_cropped_resized",
        "video_backend": "pyav"
    },
    "policy": {
        "type": "reward_classifier",
        "model_name": "helper2424/resnet10",
        "model_type": "cnn",
        "num_cameras": 4,
        "num_classes": 2,
        "hidden_dim": 256,
        "dropout_rate": 0.1,
        "learning_rate": 1e-4,
        "device": "cuda",
        "use_amp": true,
        "push_to_hub": false,
        "input_features": {
            "observation.images.head_left": {
                "type": "VISUAL",
                "shape": [3, 128, 128]
            },
            "observation.images.head_right": {
                "type": "VISUAL",
                "shape": [3, 128, 128]
            }
        }
    },
    "batch_size": 16,
    "num_workers": 4,
    "steps": 6000,
    "log_freq": 10,
    "eval_freq": 1000,
    "save_freq": 1000,
    "save_checkpoint": true,
    "seed": 2,
    "resume": false,
    "optimizer": {
        "grad_clip_norm": 10.0
    },
    "wandb": {
        "enable": false,
        "project": "reward-classifier-packing_box",
        "disable_artifact": false
    },
    "job_name": "reward-classifier-packing_box"
}